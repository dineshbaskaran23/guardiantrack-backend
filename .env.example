# =============================================
# GuardianTrack — Environment Variables
# =============================================
# 1. Copy this file and rename it to .env
# 2. Fill in MONGO_URI and FAST2SMS_KEY
# 3. Leave everything else as-is for local dev
# =============================================

NODE_ENV=development
PORT=3000

# ── REQUIRED: Get from MongoDB Atlas (free) ──
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/guardiantrack

# ── REQUIRED: Get from fast2sms.com (free account) ──
FAST2SMS_KEY=your_fast2sms_api_key_here

# ── Pre-generated secrets (safe to use as-is for local dev) ──
JWT_SECRET=a132980bb214f05be05d7e154b156eb69591c73b8556b299f0ab33d6dedc6fa8
JWT_EXPIRES_IN=30d
DEVICE_SECRET=e88fb9b3328618f62564e6e3dc19fd7671f49fd0b5409c230091e5aafc932aae
SESSION_SECRET=7700c8b21135b1909501e52661fd7c7cff492f4a4652a394c212c658a1f93ff1

# ── App settings ──
BATTERY_ALERT_THRESHOLD=20
OFFLINE_ALERT_MINUTES=15
DEFAULT_GEOFENCE_RADIUS_M=500
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
USE_FAST2SMS=true

# ── Optional: Twilio (international SMS) ──
# TWILIO_SID=your_twilio_sid
# TWILIO_TOKEN=your_twilio_token
# TWILIO_FROM=+1234567890
